# Neon Postgres
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.aws.neon.tech/neondb?sslmode=require"

# ─── Rampex ─────────────────────────────────────────────────────────────────
RAMPEX_API_KEY=rpx_your_api_key
RAMPEX_WEBHOOK_SECRET=your_webhook_secret

# ─── Supabase Storage (admin uploads, max 10MB) ─────────────────────────────
# Dashboard (new names):
#   Project URL          → SUPABASE_URL
#   Secret key           → SUPABASE_SECRET_KEY   ← USE THIS (server only)
#   Publishable key      → NOT needed for admin upload
#
# 1. Settings → API Keys: copy Project URL + Secret key
# 2. Storage → New bucket: tour-media → Public: ON
# 3. Vercel env + Redeploy
#
# (Legacy names still work: SUPABASE_SERVICE_ROLE_KEY)

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=your_secret_key_here
# SUPABASE_SERVICE_ROLE_KEY=...   # optional alias of Secret key
SUPABASE_STORAGE_BUCKET=tour-media

# Site
NEXT_PUBLIC_SITE_URL=https://testpeyment-cjss.vercel.app
NEXT_PUBLIC_SITE_NAME=TajDiscoveryPro
COMPANY_EMAIL=bookings@wildfrontier.com
COMPANY_ADDRESS=International Tour Operator

ADMIN_PASSWORD=change_me
