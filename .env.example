# Neon Postgres
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-lucky-waterfall-ad4u30lw-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── PayPal LIVE (production) ───────────────────────────────────────────────
# 1. Create LIVE app: https://developer.paypal.com/dashboard/applications/live
# 2. Copy Live Client ID + Secret (NOT sandbox)
# 3. Set all 5 vars below in Vercel → Settings → Environment Variables → Production
# 4. Set NEXT_PUBLIC_SITE_URL to your real domain (e.g. https://testpeyment.vercel.app)
# 5. Redeploy after saving env vars
# 6. Test: GET https://your-site.com/api/payments/paypal/test → ok: true, mode: "live"

NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_LIVE_client_id
PAYPAL_CLIENT_SECRET=your_LIVE_secret
PAYPAL_MODE=live
NEXT_PUBLIC_PAYPAL_MODE=live

# ─── PayPal SANDBOX (testing only) ──────────────────────────────────────────
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_sandbox_client_id
# PAYPAL_CLIENT_SECRET=your_sandbox_secret
# PAYPAL_MODE=sandbox
# NEXT_PUBLIC_PAYPAL_MODE=sandbox

# ─── Rampex (card checkout → USDC on Polygon) ───────────────────────────────
# Dashboard: https://rampex.io → Settings → API Keys / Webhooks
# Webhook URL: https://YOUR_DOMAIN/api/payments/rampex/webhook
# Test: GET https://YOUR_DOMAIN/api/payments/rampex/test

RAMPEX_API_KEY=rpx_your_api_key
RAMPEX_WEBHOOK_SECRET=your_webhook_secret
# RAMPEX_PROVIDER=hosted
# RAMPEX_API_BASE=https://api.rampex.io

# Site (REQUIRED for live PayPal/Rampex return URLs)
NEXT_PUBLIC_SITE_URL=https://testpeyment-cjss.vercel.app
NEXT_PUBLIC_SITE_NAME=TajDiscoveryPro
COMPANY_EMAIL=bookings@wildfrontier.com
COMPANY_ADDRESS=International Tour Operator

ADMIN_PASSWORD=change_me